<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.project.mapper.FaqMapper">

    <select id="selectByCategoryOptional" resultType="com.example.project.pojo.entity.Faq">
        SELECT id,
               category,
               question,
               answer,
               sort_order,
               created_at
        FROM faq
        <where>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
        </where>
        ORDER BY category, sort_order ASC, id ASC
    </select>
</mapper>
